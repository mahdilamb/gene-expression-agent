{
  "name": "owkin-chat-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "mock": "node scripts/mock-server.mjs",
    "dev:mock": "concurrently \"PORT=8001 yarn mock\" \"AGENT_URL=http://localhost:8001 vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "openapi": "python scripts/export_openapi.py && yarn openapi-ts",
    "openapi-ts": "openapi-typescript src/api/openapi.json -o src/api/schema.d.ts",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "marked": "^18.0.2",
    "openapi-fetch": "^0.17.0",
    "plotly.js-basic-dist-min": "^3.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "msw": "^2.13.2",
    "openapi-typescript": "^7.13.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
